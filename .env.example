# Ultrahuman Partner API – copy to .env and fill in. Never commit .env or real tokens.
# Get token from Ultrahuman partner onboarding. API expects raw token in Authorization header (no "Bearer " prefix).
# User must share data via Partner ID in the app (Profile → Settings → Partner ID).

ULTRAHUMAN_TOKEN=
ULTRAHUMAN_EMAIL=
# Optional (defaults match https://partner.ultrahuman.com/api/v1/metrics):
# ULTRAHUMAN_BASE_URL=https://partner.ultrahuman.com
# ULTRAHUMAN_API_PATH=/api/v1/metrics
# Optional: set to 1 for Watson-style JSON logging (trace_id, duration_ms, etc.)
# ULTRAHUMAN_LOG_JSON=1
